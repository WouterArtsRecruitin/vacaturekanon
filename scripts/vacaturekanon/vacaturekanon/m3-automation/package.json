{
  "name": "vacaturekanon-template-builder",
  "version": "1.0.0",
  "description": "Template automation voor Vacaturekanon landing pages",
  "main": "template-builder.js",
  "type": "module",
  "scripts": {
    "build:prospect": "node template-builder.js --type prospect --input example-prospect.json --output output/prospect.html",
    "build:kandidaat": "node template-builder.js --type kandidaat --input example-kandidaat.json --output output/kandidaat.html",
    "build:all": "npm run build:prospect && npm run build:kandidaat"
  },
  "dependencies": {
    "minimist": "^1.2.8"
  },
  "engines": {
    "node": ">=18"
  }
}
